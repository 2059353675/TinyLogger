{
    "buffer_size": 1024,
    "overflow_policy": "Discard",
    "printers": [
        {
            "type": "Console",
            "level": "Debug"
        },
        {
            "type": "File",
            "level": "Info",
            "path": "example.log",
            "max_size": 1048576,
            "flush_every": 64
        }
    ]
}